{
  "manifest_version": 3,
  "name": "Master summarizer",
  "version": "2.0",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["http://localhost:3000/*"],
  "icons": {
    "128" : "sav-file.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}